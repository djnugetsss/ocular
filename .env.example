# Copy to `.env.local` and fill in from your Supabase project's
# Settings -> API page. Restart the bundler with `npx expo start --clear` after
# changing these: EXPO_PUBLIC_* values are inlined at build time, so a running
# Metro instance will keep serving the old ones.
#
# Both values below ship inside the app binary and are readable by anyone with
# the IPA. That is expected — the anon key is designed to be public, and every
# table is protected by row-level security. Never put a service-role key here.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional. Set by `eas init`; enables OTA updates and links builds to a project.
# EAS_PROJECT_ID=
# EXPO_OWNER=
